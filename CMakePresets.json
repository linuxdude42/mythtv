{
"version": 1,
    "configurePresets": [
        {
            "name": "ci-base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "build-${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": {
                    "type": "STRING",
                    "value": "Debug"
                }
            }
        },
        {
            "name": "ci-sibling-build",
            "hidden": true,
            "cacheVariables": {
                "LIBS_INSTALL_PREFIX": {
                    "type": "PATH",
                    "value": "${sourceDir}/libsinstall-${presetName}"
                }
            }
        },
        {
            "name": "ci-android",
            "hidden": true,
            "cacheVariables": {
                "ANDROID_SDK_BUILD_TOOLS_REVISION": "34.0.0",
                "ANDROID_PLATFORM": "android-34",
                "CMAKE_ANDROID_NDK": {
                    "type": "PATH",
                    "value": "$env{HOME}/Android/Sdk/ndk/26.1.10909125"
                }
            }
        },
        {
            "name": "ci-qt6",
            "hidden": true,
            "cacheVariables": {
                "QT_VERSION_MAJOR": {
                    "type": "STRING",
                    "value": "6"
                }
            }
        },
        {
            "name": "ci-qt6-android",
            "inherits": [ "ci-qt6", "ci-android" ],
            "hidden": true
        },

        {
            "name": "qt6",
            "inherits": [ "ci-base", "ci-qt6" ],
            "displayName": "Native system qt6"
        },

        {
            "name": "android-v7-qt6",
            "inherits": [ "ci-base", "ci-sibling-build", "ci-qt6-android" ],
            "displayName": "Android armeabi-v7a qt6 (separate lib install)",
            "cacheVariables": {
                "CMAKE_ANDROID_ARCH_ABI": {
                    "type": "STRING",
                    "value": "armeabi-v7a"
                }
            }
        },

        {
            "name": "android-v8-qt6",
            "inherits": [ "ci-base", "ci-sibling-build", "ci-qt6-android" ],
            "displayName": "Android arm64-v8a qt6 (separate lib install)",
            "cacheVariables": {
                "CMAKE_ANDROID_ARCH_ABI": {
                    "type": "STRING",
                    "value": "arm64-v8a"
                }
            }
        },

        {
            "name": "android-x86-qt6",
            "inherits": [ "ci-base", "ci-sibling-build", "ci-qt6-android" ],
            "displayName": "Android x86 qt6 (separate lib install)",
            "cacheVariables": {
                "CMAKE_ANDROID_ARCH_ABI": {
                    "type": "STRING",
                    "value": "x86"
                }
            }
        },

        {
            "name": "android-x86_64-qt6",
            "inherits": [ "ci-base", "ci-sibling-build", "ci-qt6-android" ],
            "displayName": "Android x86_64 qt6 (separate lib install)",
            "cacheVariables": {
                "CMAKE_ANDROID_ARCH_ABI": {
                    "type": "STRING",
                    "value": "x86_64"
                }
            }
        },


        {
            "vendor": {
                "company": "Amazon",
                "name": "Fire Stick 4K Max 1st Generation",
                "osver": "Fire OS 7",
                "androidver": "9",
                "androidapilevel": "28"
            },
            "name": "fire-stick-4k-max-qt6",
            "inherits": [ "android-v7-qt6", "ci-sibling-build" ],
            "displayName": "Fire Stick 4K Max qt6 (separate lib install)",
            "cacheVariables": {
                "ANDROID_MIN_SDK_VERSION": "25",
                "ANDROID_TARGET_SDK_VERSION": "28"
            }
        },
        {
            "vendor": {
                "company": "Nvidia",
                "name": "Shield Android TV",
                "osver": "9.1.1(33.2.0.157)",
                "androidver": "11",
                "androidapilevel": "30"
            },
            "name": "nvidia-shield-qt6",
            "inherits": [ "android-v8-qt6", "ci-sibling-build" ],
            "displayName": "Nvidia Shield qt6 (separate lib install)",
            "cacheVariables": {
                "ANDROID_MIN_SDK_VERSION": "25",
                "ANDROID_TARGET_SDK_VERSION": "29"
            }
        },


        {
            "name": "mingw-qt6",
            "inherits": [ "ci-base", "ci-sibling-build", "ci-qt6" ],
            "displayName": "Windows qt6 (separate lib install)",
            "cacheVariables":
            {
                "CMAKE_TOOLCHAIN_FILE": {
                    "type": "FILEPATH",
                    "value": "${sourceDir}/cmake/mingw-w64-x86_64.cmake"
                }
            }
        }

    ]
}
