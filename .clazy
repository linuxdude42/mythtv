// For the full list of available checks:
//
//   https://github.com/KDE/clazy#list-of-checks

// BASE LEVEL
level1

////////////////////////////////////////
// MANUAL CHECKS - need to be explicitly enabled

assert-with-side-effects
container-inside-loop
heap-allocated-small-trivial-type
ifndef-define-typo
isempty-vs-count
qhash-with-char-pointer-key
qproperty-type-mismatch
qrequiredresult-candidates
qstring-ref
qvariant-template-instantiation
raw-environment-function
reserve-candidates
tr-non-literal
unneeded-cast
use-arrow-operator-instead-of-data
use-chrono-in-qtimer

// As of 2026-07-17, this check crashes clazy.
//
// compare-member-check

// Not needed. The QT_DISABLE_DEPRECATED_*/QT_ENABLE_STRICT_MODE_UP_TO
// compile time argument prevents this case.
//
// qbytearray-conversion-to-c-style

// This check isn't useful on the MythTV code base.
// 
// qstring-varargs

// Not needed.  MythTV uses [[maybe_unused]] instead of Q_UNUSED.
//
// used-qunused-variable

// Flag potential conflicts with the C++20 keyword 'emit'.  The emit()
// function is defined in the 'syncscream' header, so changes are not
// needed until that header file is included by a file.  As of
// 2026-07-17, there are 733 unique instances of this warning.
//
// qt-keyword-emit

// Not needed unless we decide to switch to using Q_EMIT, etc.  As of
// 2026-07-17, there are 1322 unique uses of the keywords 'emit',
// 'slots', and 'signals'.
//
// qt-keywords

//////////

// As of 2026-07-17, there are 977 unique instances of calls to
// potentially detaching functions.
//
// detaching-member

// As of 2026-07-17, there are xxx instances of this warning.
// 
// jni-signatures

// As of 2026-07-17, this check is documented but not in the current
// clang-tidy version 22.
//
// modernize-list-initialization

// Only three or four instances, but produce ~90 warnings.
//
// signal-with-return-value

// As of 2026-07-17, there is 1 instance of this warning.
//
// thread-with-slots

// As of 2026-07-17, this generates ~140 errors.
//   ~40 calls to QObject::disconnect
//   ~20 calls to ZMServer::send
//   ~10 calls to QDir::xxx
//   ~10 calls to MPEGStreamData::DeleteCachedTable
//   ~10 calls to ImageXXX::UpdateDbImage
//   lots of one-offs
// unused-result-check



////////////////////////////////////////
// LEVEL0 CHECKS - all enabled by 'level1' statement
// - disable one check

// MythTV has several instances of overloaded signals
no-overloaded-signal



////////////////////////////////////////
// LEVEL1 CHECKS - all enabled by 'level1' statement
// - disable two checks

// This flag is designed more for libraries, not executables.  It
// will, however point out global static variables, so could be
// temporarily enabled for that reason.
no-non-pod-global-static

// Only really needed for apps using QML.
no-qproperty-without-notify



////////////////////////////////////////
// LEVEL2 CHECKS - not enabled as a group. May be noisy.
// - enable some individual checks

base-class-event
function-args-by-ref
function-args-by-value
global-const-char-pointer
missing-typeinfo
old-style-connect
returning-void-expression
static-pmf
virtual-call-ctor
implicit-casts

// As of 2026-07-17, there are 671 unique instances of polymorphic
// classes that are copyable.
//
// copyable-polymorphic

// As of 2026-07-14, the constructors for 606 classes don't take a
// parent object.
//
// ctor-missing-parent-argument

// As of 2026-07-14, there are 361 classes derived from QObject that
// don't include the Q_OBJECT macro.  This macro isn't required in
// every derived object, only ones that use certain features.
// 
// missing-qobject-macro

// Qt6 is migrating from QLatin1String to c++ Unicode string literals.
// Wait until Qt5 support is removed before using the operator""_s
// function to create string literals.
//
// qstring-allocations

// As of 2026-07-17, there are 86 unique classes that violate the C++
// rule-of-three/rule-of-five.  These rules are related to object
// memory management, or lack thereof.
//
// rule-of-three
